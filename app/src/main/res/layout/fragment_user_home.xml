<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    tools:context="com.example.municipalservices.FragmentUserHome">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Welcome Section -->
            <TextView
                android:id="@+id/tv_welcome_user"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:text="@string/welcome_back"
                android:textColor="#333333"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_subtitle"
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <!-- Complaint Summary Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/my_applications"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_total_complaints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <RelativeLayout
                    android:id="@+id/rl_total_complaints"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:background="@drawable/button_rounded"
                    android:backgroundTint="@color/colorLightBlue">

                    <TextView
                        android:id="@+id/tv_total_complaints_in_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorWhite"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_complaints_submitted"
                        android:textColor="@color/colorWhite"
                        android:layout_below="@+id/tv_total_complaints_in_number"
                        android:textSize="14sp"
                        android:alpha="0.9" />

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/icon_all"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        app:tint="@color/colorWhite"
                        android:alpha="0.3"
                        android:contentDescription="@string/total_complaints"/>

                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_open_complaints"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <RelativeLayout
                        android:id="@+id/rl_open_complaints"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tv_open_complaints_in_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorRed"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/active_cases"
                            android:textColor="#888888"
                            android:layout_below="@+id/tv_open_complaints_in_number"
                            android:textSize="12sp" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_closed_complaints"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <RelativeLayout
                        android:id="@+id/rl_closed_complaints"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tv_closed_complaints_in_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorGreen"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/resolved_cases"
                            android:textColor="#888888"
                            android:layout_below="@+id/tv_closed_complaints_in_number"
                            android:textSize="12sp" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Feedback Analysis Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/feedback_insights"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <!-- Positive -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_positive_feedback"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">
                    <RelativeLayout
                        android:id="@+id/rl_positive_feedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <ImageView
                            android:id="@+id/iv_pos_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_like"
                            app:tint="@color/colorGreen"
                            android:contentDescription="@string/positive"/>
                        <TextView
                            android:id="@+id/tv_positive_feedback_in_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/iv_pos_icon"
                            android:layout_marginStart="8dp"
                            android:text="0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/iv_pos_icon"
                            android:layout_marginTop="4dp"
                            android:text="@string/positive"
                            android:textSize="11sp"
                            android:textColor="#888888"/>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Negative -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_negative_feedback"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">
                    <RelativeLayout
                        android:id="@+id/rl_negative_feedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <ImageView
                            android:id="@+id/iv_neg_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_dislike"
                            app:tint="@color/colorRed"
                            android:contentDescription="@string/negative"/>
                        <TextView
                            android:id="@+id/tv_negative_feedback_in_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/iv_neg_icon"
                            android:layout_marginStart="8dp"
                            android:text="0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/iv_neg_icon"
                            android:layout_marginTop="4dp"
                            android:text="@string/negative"
                            android:textSize="11sp"
                            android:textColor="#888888"/>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Pending -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_pending_feedback"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">
                    <RelativeLayout
                        android:id="@+id/rl_pending_feedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <ImageView
                            android:id="@+id/iv_pen_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_pending"
                            app:tint="@color/colorDarkYellow"
                            android:contentDescription="@string/pending"/>
                        <TextView
                            android:id="@+id/tv_pending_feedback_in_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/iv_pen_icon"
                            android:layout_marginStart="8dp"
                            android:text="0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/iv_pen_icon"
                            android:layout_marginTop="4dp"
                            android:text="@string/pending"
                            android:textSize="11sp"
                            android:textColor="#888888"/>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Dropped -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_dropped_feedback"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">
                    <RelativeLayout
                        android:id="@+id/rl_dropped_feedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <ImageView
                            android:id="@+id/iv_drop_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/icon_dropped"
                            app:tint="@color/colorRed"
                            android:contentDescription="@string/dropped_feedback"/>
                        <TextView
                            android:id="@+id/tv_dropped_feedback_in_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/iv_drop_icon"
                            android:layout_marginStart="8dp"
                            android:text="0"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#333333"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/iv_drop_icon"
                            android:layout_marginTop="4dp"
                            android:text="Dropped"
                            android:textSize="11sp"
                            android:textColor="#888888"/>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- Bottom Spacer to prevent FAB overlap -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        app:srcCompat="@drawable/icon_add"
        app:fabSize="normal"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@color/colorWhite"
        android:contentDescription="@string/add_new_complaint" />

</RelativeLayout>
