<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.municipalservices.UserPanelActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerInParent="true">



        <Button
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:id="@+id/btn_admin_home"
            android:textSize="30dp"
            android:onClick="userHome"
            android:text="Home"
            android:textColor="@color/colorWhite"
            android:background="@drawable/black_rounded"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginTop="15dp"
            android:id="@+id/btn_all_complaints"
            android:textSize="30dp"
            android:onClick="btnAllComplaints"
            android:text="All Complaints"
            android:textColor="@color/colorWhite"
            android:background="@drawable/black_rounded"
            />






    </LinearLayout>

</RelativeLayout>
