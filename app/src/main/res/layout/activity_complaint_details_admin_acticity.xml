<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:orientation="vertical"
    tools:context="com.example.municipalservices.ComplaintDetailsAdminActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Complaint Details Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iv_complaint_details_image"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginBottom="12dp"
                        android:background="#EEEEEE"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/complaint_details_title_str" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp"
                        android:baselineAligned="false">

                        <TextView
                            android:id="@+id/complaint_details_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Complaint Title"
                            android:textColor="#333333"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/complaint_details_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/button_rounded"
                            android:backgroundTint="@color/colorLightBlue"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="@string/pending"
                            android:textAllCaps="true"
                            android:textColor="@color/colorWhite"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/complaint_details_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID: #12345"
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/complaint_details_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Full description of the complaint goes here..."
                        android:textColor="#666666"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />

                    <Button
                        android:id="@+id/complaint_details_view_map_btn"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:onClick="openMaps"
                        android:text="@string/view_on_map"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- User Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reporter_info"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/complaint_details_user"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="User data loading..."
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Official Progress Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/official_action_log"
                        android:textColor="#333333"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/forwarded_to_label"
                            android:textStyle="bold"
                            android:textColor="#333333"/>
                        <TextView
                            android:id="@+id/tv_assigned_role"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Unassigned"
                            android:textColor="@color/colorPrimary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/official_remarks_label"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tv_remarks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_remarks_yet"
                        android:textColor="#666666"
                        android:background="#F8F9FA"
                        android:padding="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Admin Action Controls -->
            <TextView
                android:id="@+id/label_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/management_console"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"/>

            <!-- Admin specific -->
            <LinearLayout
                android:id="@+id/layout_admin_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Forward to Department"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>
                        <Spinner
                            android:id="@+id/spinnerForwardRole"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/button_rounded"
                            android:backgroundTint="#F0F2F5"/>
                        <Button
                            android:id="@+id/btn_forward"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="12dp"
                            android:text="@string/assign_department"
                            android:onClick="forwardComplaint"
                            android:textAllCaps="false"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Shared Action Panel -->
            <androidx.cardview.widget.CardView
                android:id="@+id/layout_shared_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/add_official_remarks_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_admin_remarks"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:minLines="3" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/save_remarks"
                        android:onClick="updateRemarks"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginVertical="16dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:alignmentMode="alignMargins"
                        android:columnOrderPreserved="false">

                        <Button
                            android:id="@+id/btn_in_progress"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:text="@string/in_progress"
                            android:onClick="setInProgress"
                            android:textAllCaps="false"
                            android:backgroundTint="#2196F3"
                            app:cornerRadius="12dp" />

                        <Button
                            android:id="@+id/complaint_details_approve_btn"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:text="@string/open"
                            android:onClick="approveComplaint"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/colorLightBlue"
                            app:cornerRadius="12dp" />

                        <Button
                            android:id="@+id/complaint_details_reject_btn"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:text="@string/rejected"
                            android:onClick="rejectComplaint"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/colorRed"
                            app:cornerRadius="12dp" />

                        <Button
                            android:id="@+id/complaint_details_close_btn"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:text="@string/closed"
                            android:onClick="closeComplaint"
                            android:textAllCaps="false"
                            android:backgroundTint="@color/colorGreen"
                            app:cornerRadius="12dp" />

                    </GridLayout>

                    <Button
                        android:id="@+id/complaint_details_delete_btn"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:text="@string/delete_permanently"
                        android:onClick="deleteComplaint"
                        android:textAllCaps="false"
                        android:textColor="@color/colorRed" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
